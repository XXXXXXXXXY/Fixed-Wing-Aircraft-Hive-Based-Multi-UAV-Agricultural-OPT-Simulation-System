# QGroundControl-friendly SITL defaults for local multi-vehicle testing.
# These loosen pre-arm checks so the virtual fleet can be armed and moved
# without real sensors, safety switch, or RC hardware.
ARMING_CHECK 0
BRD_SAFETY_DEFLT 0
DISARM_DELAY 0
FS_THR_ENABLE 0
FENCE_ENABLE 0
SERIAL1_PROTOCOL 2
SERIAL1_BAUD 115
SR0_EXT_STAT 2
SR0_POSITION 5
SR0_EXTRA1 2
SR0_EXTRA2 2
SR0_EXTRA3 2
SR1_EXT_STAT 2
SR1_POSITION 2
SR1_EXTRA1 2
SR1_EXTRA2 2
SR1_EXTRA3 2
